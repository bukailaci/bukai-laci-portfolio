---
// src/components/Navigation.astro
---
<nav class="fixed top-0 left-0 z-[200] w-full p-2 lg:p-4 xl:p-6">
  <div class="max-w-7xl mx-auto relative rounded-2xl border border-white/25 bg-slate-950/20 backdrop-blur-2xl backdrop-saturate-150 shadow-[0_20px_50px_rgba(0,0,0,0.6)]">

    <div class="absolute inset-0 -z-10 rounded-2xl overflow-hidden pointer-events-none">
      <div class="animated-gradient absolute inset-0 opacity-50"></div>
    </div>

    <div class="px-4 lg:px-5 xl:px-8 h-20 flex items-center justify-between relative">

      <div class="flex items-center gap-2 lg:gap-3 xl:gap-4 z-[220]">
        <a href="/" class="text-lg lg:text-xl xl:text-2xl font-black bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 via-blue-400 to-emerald-400 uppercase tracking-tighter whitespace-nowrap">
          BUKAI LACI
        </a>

        {/* PayPal Szentély (ID: QD89ND9B7ZD5C) */}
        <form action="https://www.paypal.com/donate" method="post" target="_blank" class="flex items-center">
          <input name="hosted_button_id" type="hidden" value="QD89ND9B7ZD5C" />
          <button
            type="submit"
            title="Támogatás"
            class="px-2 py-1 rounded-lg border border-white/10 bg-white/5 text-[8px] lg:text-[9px] font-bold text-slate-400 uppercase tracking-widest hover:bg-cyan-500/10 hover:border-cyan-500/50 hover:text-cyan-400 transition-all cursor-pointer whitespace-nowrap"
          >
            Támogatás
          </button>
        </form>
      </div>

      <button id="menu-toggle" class="lg:hidden z-[220] text-white p-2 outline-none" aria-label="Menü">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="menu-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <div id="nav-menu" class="hidden lg:flex fixed lg:static inset-0 w-full h-[100dvh] lg:h-auto bg-slate-950 lg:bg-transparent flex-col lg:flex-row items-center justify-center lg:justify-end gap-6 lg:gap-2 xl:gap-6 pt-20 lg:pt-0 z-[210] overflow-y-auto lg:overflow-visible pb-20 lg:pb-0">

        <div class="nav-links flex flex-col lg:flex-row items-center gap-6 lg:gap-2 xl:gap-5">
          <a href="/" class="text-2xl lg:text-[9px] xl:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em]">Kezdőlap</a>
          <a href="/rolam" class="text-2xl lg:text-[9px] xl:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em]">Rólam</a>

          {/* Csillagok - Most már ez is "buta", csak hoverre reagál */}
          <a href="/csillagok" class="text-2xl lg:text-[9px] xl:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em]">Csillagok</a>

          {/* Galéria Dropdown */}
          <div class="relative group dropdown-parent flex flex-col lg:flex-row items-center lg:h-20">
            <button class="dropdown-toggle flex items-center gap-1 text-2xl lg:text-[9px] xl:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em] outline-none">
                Galéria
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" /></svg>
            </button>
            <div class="dropdown-menu lg:absolute lg:top-full lg:left-1/2 lg:-translate-x-1/2 hidden flex-col z-[250] w-full lg:w-48">
                <div class="bg-slate-900/95 backdrop-blur-3xl border border-white/20 rounded-2xl p-2 shadow-2xl flex flex-col gap-1 mt-2">
                  <a href="/galeria" class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 px-4 py-3 rounded-xl transition-all uppercase tracking-widest italic">Fotógaléria</a>
                </div>
            </div>
          </div>

          {/* Videók Dropdown */}
          <div class="relative group dropdown-parent flex flex-col lg:flex-row items-center lg:h-20">
            <button class="dropdown-toggle flex items-center gap-1 text-2xl lg:text-[9px] xl:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em] outline-none">
                Videók
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" /></svg>
            </button>
            <div class="dropdown-menu lg:absolute lg:top-full lg:left-1/2 lg:-translate-x-1/2 hidden flex-col z-[250] w-full lg:w-64">
                <div class="bg-slate-900/95 backdrop-blur-3xl border border-white/20 rounded-2xl p-2 shadow-2xl flex flex-col gap-1 mt-2">
                  <a href="/videok/omega-forever" class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 px-4 py-3 rounded-xl transition-all uppercase tracking-widest italic">Omega Forever</a>
                  <a href="/videok/locomotiv-revival" class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 px-4 py-3 rounded-xl transition-all uppercase tracking-widest italic">Locomotiv Revival</a>
                </div>
            </div>
          </div>

          {/* AI Szekció (Aranyszabály) */}
          <div class="relative group dropdown-parent flex flex-col lg:flex-row items-center lg:h-20">
            <button class="dropdown-toggle flex items-center gap-1 text-2xl lg:text-[9px] xl:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em] outline-none">
                AI
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" /></svg>
            </button>
            <div class="dropdown-menu lg:absolute lg:top-full lg:left-1/2 lg:-translate-x-1/2 hidden flex-col z-[250] w-full lg:w-48">
                <div class="bg-slate-900/95 backdrop-blur-3xl border border-white/20 rounded-2xl p-2 shadow-2xl flex flex-col gap-1 mt-2">
                  <a href="/ai-kepek" class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 px-4 py-3 rounded-xl transition-all uppercase tracking-widest italic">AI Fotók</a>
                  <a href="/ai-videok" class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 px-4 py-3 rounded-xl transition-all uppercase tracking-widest italic">AI Videók</a>
                </div>
            </div>
          </div>

          <a href="/koncertek" class="text-2xl lg:text-[9px] xl:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em]">Koncertek</a>
        </div>

        <div class="flex flex-col lg:flex-row items-center gap-6 lg:gap-2 xl:gap-4 mt-8 lg:mt-0 lg:ml-1">
          {/* Facebook megosztó (Aranyszabály) */}
          <a href="https://www.facebook.com/sharer/sharer.php?u=https://www.bukailaci.eu" target="_blank" class="text-slate-400 hover:text-blue-500 transition-all" aria-label="Facebook">
            <svg class="w-6 h-6 lg:w-5 lg:h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
          </a>
          <a id="contact-btn" href="/kapcsolat" class="px-8 py-4 lg:px-2 lg:py-1.5 xl:px-5 bg-cyan-500/20 hover:bg-cyan-500 text-cyan-400 hover:text-white border border-cyan-500/50 rounded-xl font-black lg:font-bold uppercase tracking-widest text-sm lg:text-[8px] xl:text-[11px] transition-all whitespace-nowrap">
            Kapcsolat
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  .animated-gradient {
    background: linear-gradient(125deg, #06b6d4, #3b82f6, #10b981, #8b5cf6, #06b6d4);
    background-size: 250% 250%;
    animation: glow-flow 8s linear infinite;
  }
  @keyframes glow-flow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* 1024px TÚLÉLŐMÓD (Aranyszabály) */
  @media (min-width: 1024px) and (max-width: 1280px) {
    .nav-links { gap: 0.4rem !important; }
    #contact-btn { padding-left: 0.4rem !important; padding-right: 0.4rem !important; font-size: 7px !important; }
  }

  /* 1281px FELETT: CSS Hover (Aranyszabály) */
  @media (min-width: 1281px) {
    .dropdown-parent:hover .dropdown-menu {
      display: flex !important;
    }
  }
</style>

<script>
  function setupNavigation() {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('nav-menu');
    const path = document.getElementById('menu-path');

    if (!btn || !menu || !path) return;

    btn.onclick = () => {
      const isHidden = menu.classList.contains('hidden');
      if (isHidden) {
        menu.classList.remove('hidden'); menu.classList.add('flex');
        path.setAttribute('d', 'M6 18L18 6M6 6l12 12');
      } else {
        menu.classList.add('hidden'); menu.classList.remove('flex');
        path.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      }
    };

    document.querySelectorAll('.dropdown-toggle').forEach(toggleBtn => {
      toggleBtn.onclick = (e) => {
        // 1280px határ (Aranyszabály: kattintásra működik)
        if (window.innerWidth <= 1280) {
          const dropdownMenu = toggleBtn.nextElementSibling;
          const icon = toggleBtn.querySelector('svg');

          if (dropdownMenu) {
            const isHidden = dropdownMenu.classList.contains('hidden');
            document.querySelectorAll('.dropdown-menu').forEach(m => {
              if (m !== dropdownMenu) m.classList.add('hidden');
            });

            if (isHidden) {
              dropdownMenu.classList.remove('hidden'); dropdownMenu.classList.add('flex');
              icon?.classList.add('rotate-180');
            } else {
              dropdownMenu.classList.add('hidden'); dropdownMenu.classList.remove('flex');
              icon?.classList.remove('rotate-180');
            }
          }
        }
      };
    });

    document.addEventListener('click', (e) => {
      if (window.innerWidth <= 1280 && !e.target.closest('.dropdown-parent')) {
        document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('hidden'));
        document.querySelectorAll('.dropdown-toggle svg').forEach(s => s.classList.remove('rotate-180'));
      }
    });
  }

  setupNavigation();
  document.addEventListener('astro:after-swap', setupNavigation);
  document.addEventListener('astro:page-load', setupNavigation);
</script>