---
// src/components/Navigation.astro
---

<nav class="fixed top-0 left-0 z-200 w-full p-4 md:p-6">
  <div
    class="max-w-7xl mx-auto relative rounded-2xl border border-white/25 bg-slate-950/20 backdrop-blur-2xl backdrop-saturate-150 shadow-[0_20px_50px_rgba(0,0,0,0.6)]"
  >
    <div
      class="absolute inset-0 -z-10 rounded-2xl overflow-hidden pointer-events-none"
    >
      <div class="animated-gradient absolute inset-0 opacity-50"></div>
    </div>

    <div class="px-6 h-20 flex items-center justify-between relative">
      <a
        href="/"
        class="text-xl md:text-2xl font-black bg-clip-text text-transparent bg-linear-to-r from-cyan-400 via-blue-400 to-emerald-400 z-220 uppercase tracking-tighter whitespace-nowrap"
      >
        BUKAI LACI
      </a>

      <button
        id="menu-toggle"
        class="lg:hidden z-220 text-white p-2 outline-none"
        aria-label="Menü"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-8 w-8"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            id="menu-path"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <div
        id="nav-menu"
        class="hidden lg:flex fixed lg:static inset-0 w-full h-dvh lg:h-auto bg-slate-950 lg:bg-transparent flex-col lg:flex-row items-center justify-center lg:justify-end gap-8 lg:gap-6 pt-20 lg:pt-0 z-210 overflow-y-auto lg:overflow-visible pb-20 lg:pb-0"
      >
        <a
          href="/"
          class="text-2xl lg:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em]"
          >Kezdőlap</a
        >
        <a
          href="/rolam"
          class="text-2xl lg:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em]"
          >Rólam</a
        >

        <div class="relative group dropdown-parent">
          <button
            class="dropdown-toggle flex items-center gap-1 text-2xl lg:text-[11px] font-black lg:font-extrabold text-white/90 group-hover:text-cyan-400 transition-colors uppercase tracking-[0.2em] outline-none"
          >
            Galéria
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </button>
          <div
            class="dropdown-menu lg:absolute lg:top-full lg:left-1/2 lg:-translate-x-1/2 lg:pt-4 hidden group-hover:flex flex-col z-250"
          >
            <div
              class="bg-slate-900/95 backdrop-blur-3xl border border-white/20 rounded-2xl p-2 lg:w-48 shadow-2xl flex flex-col gap-1 overflow-hidden"
            >
              {/* JAVÍTÁS: pr-6, italic és tracking-tighter hozzáadva */}
              <a
                href="/galeria"
                class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 pl-4 pr-6 py-3 rounded-xl transition-all uppercase tracking-tighter whitespace-nowrap italic"
                >Fotógaléria</a
              >
            </div>
          </div>
        </div>

        <div class="relative group dropdown-parent">
          <button
            class="dropdown-toggle flex items-center gap-1 text-2xl lg:text-[11px] font-black lg:font-extrabold text-white/90 group-hover:text-cyan-400 transition-colors uppercase tracking-[0.2em] outline-none"
          >
            Videók
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </button>
          <div
            class="dropdown-menu lg:absolute lg:top-full lg:left-1/2 lg:-translate-x-1/2 lg:pt-4 hidden group-hover:flex flex-col z-250"
          >
            <div
              class="bg-slate-900/95 backdrop-blur-3xl border border-white/20 rounded-2xl p-2 lg:w-64 shadow-2xl flex flex-col gap-1 overflow-hidden"
            >
              {
                /* JAVÍTÁS: Zenekarnevek fixálva pr-6, italic és tracking-tighter osztályokkal */
              }
              <a
                href="/videok/omega-forever"
                class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 pl-4 pr-6 py-3 rounded-xl transition-all uppercase tracking-tighter whitespace-nowrap italic"
                >Omega Forever Band</a
              >
              <a
                href="/videok/locomotiv-revival"
                class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 pl-4 pr-6 py-3 rounded-xl transition-all uppercase tracking-tighter whitespace-nowrap italic"
                >Locomotiv Revival Band</a
              >
            </div>
          </div>
        </div>

        <div class="relative group dropdown-parent">
          <button
            class="dropdown-toggle flex items-center gap-1 text-2xl lg:text-[11px] font-black lg:font-extrabold text-white/90 group-hover:text-cyan-400 transition-colors uppercase tracking-[0.2em] outline-none"
          >
            AI
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </button>
          <div
            class="dropdown-menu lg:absolute lg:top-full lg:left-1/2 lg:-translate-x-1/2 lg:pt-4 hidden group-hover:flex flex-col z-250"
          >
            <div
              class="bg-slate-900/95 backdrop-blur-3xl border border-white/20 rounded-2xl p-2 lg:w-48 shadow-2xl flex flex-col gap-1 overflow-hidden"
            >
              <a
                href="/ai-kepek"
                class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 pl-4 pr-6 py-3 rounded-xl transition-all uppercase tracking-tighter whitespace-nowrap italic"
                >AI Fotók</a
              >
              <a
                href="/ai-videok"
                class="w-full text-center lg:text-left text-xl lg:text-[11px] font-bold text-white hover:bg-cyan-500/20 hover:text-cyan-400 pl-4 pr-6 py-3 rounded-xl transition-all uppercase tracking-tighter whitespace-nowrap italic"
                >AI Videók</a
              >
            </div>
          </div>
        </div>

        <a
          href="/koncertek"
          class="text-2xl lg:text-[11px] font-black lg:font-extrabold text-white/90 hover:text-cyan-400 transition-colors uppercase tracking-[0.2em]"
          >Koncertek</a
        >

        <div
          class="flex flex-col lg:flex-row items-center gap-6 lg:gap-4 mt-8 lg:mt-0 lg:ml-4"
        >
          <a
            href="https://www.facebook.com/sharer/sharer.php?u=https://www.bukailaci.eu"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-blue-500 transition-all hover:scale-110"
            aria-label="Megosztás Facebookon"
          >
            <svg
              class="w-6 h-6 lg:w-5 lg:h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"
              ></path>
            </svg>
          </a>
          <a
            href="/kapcsolat"
            class="px-8 py-4 lg:px-6 lg:py-2 bg-cyan-500/20 hover:bg-cyan-500 text-cyan-400 hover:text-white border border-cyan-500/50 rounded-xl font-black lg:font-bold uppercase tracking-widest text-sm lg:text-[11px] transition-all duration-300"
          >
            Kapcsolat
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  .animated-gradient {
    background: linear-gradient(
      125deg,
      #06b6d4,
      #3b82f6,
      #10b981,
      #8b5cf6,
      #06b6d4
    );
    background-size: 250% 250%;
    animation: glow-flow 8s linear infinite;
  }
  @keyframes glow-flow {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
</style>

<script>
  interface ClickEvent extends MouseEvent {
    target: EventTarget & { closest: (selector: string) => Element | null };
  }

  function setupNavigation() {
    const btn = document.getElementById(
      "menu-toggle",
    ) as HTMLButtonElement | null;
    const menu = document.getElementById("nav-menu") as HTMLDivElement | null;
    const path = document.getElementById("menu-path") as SVGPathElement | null;

    if (!btn || !menu || !path) return;

    btn.addEventListener("click", () => {
      const isHidden = menu.classList.contains("hidden");
      if (isHidden) {
        menu.classList.remove("hidden");
        menu.classList.add("flex");
        path.setAttribute("d", "M6 18L18 6M6 6l12 12");
      } else {
        menu.classList.add("hidden");
        menu.classList.remove("flex");
        path.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
      }
    });

    // Dropdown kezelés mobilon
    document.querySelectorAll(".dropdown-toggle").forEach((btn) => {
      (btn as HTMLButtonElement).addEventListener("click", (e: Event) => {
        if (window.innerWidth <= 1280) {
          const dropdownMenu = btn.nextElementSibling as HTMLDivElement | null;
          const icon = btn.querySelector("svg") as SVGElement | null;

          if (dropdownMenu && icon) {
            const isHidden = dropdownMenu.classList.contains("hidden");

            document.querySelectorAll(".dropdown-menu").forEach((m) => {
              if (m !== dropdownMenu) m.classList.add("hidden");
            });
            document.querySelectorAll(".dropdown-toggle svg").forEach((s) => {
              if (s !== icon) s.classList.remove("rotate-180");
            });

            if (isHidden) {
              dropdownMenu.classList.remove("hidden");
              dropdownMenu.classList.add("flex");
              icon.classList.add("rotate-180");
            } else {
              dropdownMenu.classList.add("hidden");
              dropdownMenu.classList.remove("flex");
              icon.classList.remove("rotate-180");
            }
          }
        }
      });
    });

    document.addEventListener("click", (e: Event) => {
      const target = e.target as HTMLElement | null;
      if (target && !target.closest(".dropdown-parent")) {
        document
          .querySelectorAll(".dropdown-menu")
          .forEach((m) => m.classList.add("hidden"));
        document
          .querySelectorAll(".dropdown-toggle svg")
          .forEach((s) => s.classList.remove("rotate-180"));
      }
    });
  }

  setupNavigation();
  document.addEventListener("astro:after-swap", setupNavigation);
  document.addEventListener("astro:page-load", setupNavigation);
</script>
