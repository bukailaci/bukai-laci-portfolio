---
// src/components/BackToTop.astro
---

<button
  id="back-to-top"
  class="fixed bottom-8 right-8 z-50 p-4 rounded-2xl bg-slate-900/50 backdrop-blur-xl border border-white/10 text-cyan-400 shadow-2xl transition-all duration-500 opacity-0 invisible translate-y-10 hover:-translate-y-1 hover:border-cyan-500/50 group"
  aria-label="Vissza a tetejére"
>
  <div class="absolute inset-0 -z-10 overflow-visible pointer-events-none">
    <div class="animated-gradient absolute inset-0 opacity-0 group-hover:opacity-40 blur-[20px] transition-all duration-700 rounded-2xl"></div>
  </div>

  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-6 w-6 transition-transform duration-300 group-hover:-translate-y-1"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2.5"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
  </svg>
</button>

<style>
  .animated-gradient {
    background: linear-gradient(125deg, #06b6d4, #3b82f6, #10b981, #8b5cf6, #06b6d4);
    background-size: 250% 250%;
    animation: glow-flow 8s linear infinite;
  }
  @keyframes glow-flow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
</style>

<script>
  function setupBackToTop() {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;

    // Megjelenítés/elrejtés görgetéskor
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        btn.classList.remove('opacity-0', 'invisible', 'translate-y-10');
        btn.classList.add('opacity-100', 'visible', 'translate-y-0');
      } else {
        btn.classList.add('opacity-0', 'invisible', 'translate-y-10');
        btn.classList.remove('opacity-100', 'visible', 'translate-y-0');
      }
    });

    // Görgetés a tetejére kattintáskor
    btn.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }

  // Inicializálás betöltéskor és Astro oldalváltáskor
  setupBackToTop();
  document.addEventListener('astro:after-swap', setupBackToTop);
</script>
