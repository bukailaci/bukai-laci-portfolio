---
// src/components/Stars.astro
---
<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
  <canvas id="constellation-canvas" class="absolute inset-0 z-10"></canvas>
</div>

<script>
  function initConstellation() {
    const canvas = document.getElementById("constellation-canvas") as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    let particles: any[] = [];
    let mouse = { x: null, y: null };
    let connectionDist = 160;
    let currentCount = 0;
    let currentColor = { r: 34, g: 211, b: 238 }; // Alapértelmezett kék (cyan-400)

    // Segédfüggvény a Hex szín RGBA-vá alakításához
    const hexToRgb = (hex) => {
      const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
      return result ? {
        r: parseInt(result[1], 16),
        g: parseInt(result[2], 16),
        b: parseInt(result[3], 16)
      } : null;
    };

    window.addEventListener("mousemove", (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
    window.addEventListener("mouseleave", () => { mouse.x = null; mouse.y = null; });

    const createParticles = (count) => {
      currentCount = count;
      particles = Array.from({ length: count }, () => ({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        size: Math.random() * 1.5 + 0.5,
        blinkOffset: Math.random() * Math.PI * 2,
        blinkSpeed: 0.004 + Math.random() * 0.006,
      }));
    };

    const resize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      const area = canvas.width * canvas.height;
      const dynamicCount = Math.min(Math.max(Math.floor(area / 8000), 60), 350);
      connectionDist = Math.min(Math.max(canvas.width / 15 + 100, 110), 230);
      createParticles(currentCount || dynamicCount);
    };

    // KONFIGURÁCIÓ FRISSÍTÉSE (Szín és Szám)
    window.addEventListener('updateStarConfig', (e: any) => {
      const { count, color } = e.detail;
      const rgb = hexToRgb(color);
      if (rgb) currentColor = rgb;
      if (count !== currentCount) createParticles(count);
    });

    const animate = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const time = Date.now();
      const colorStr = `${currentColor.r}, ${currentColor.g}, ${currentColor.b}`;

      particles.forEach((p, i) => {
        p.x += p.vx; p.y += p.vy;

        // Taszítás
        if (mouse.x !== null && mouse.y !== null) {
          const dx = p.x - mouse.x;
          const dy = p.y - mouse.y;
          const distance = Math.hypot(dx, dy);
          if (distance < 150 && distance > 0) {
            const force = (150 - distance) / 150;
            p.x += (dx / distance) * force * 3;
            p.y += (dy / distance) * force * 3;
          }
        }

        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

        const blink = Math.sin(time * p.blinkSpeed + p.blinkOffset);
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size * (1 + blink * 0.3), 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${colorStr}, ${0.5 + blink * 0.4})`;
        ctx.fill();

        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < connectionDist) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(${colorStr}, ${0.4 * (1 - dist / connectionDist)})`;
            ctx.lineWidth = 0.4;
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.stroke();
          }
        }
      });
      requestAnimationFrame(animate);
    };

    window.addEventListener("resize", resize);
    resize();
    animate();
  }

  initConstellation();
  document.addEventListener("astro:page-load", initConstellation);
</script>