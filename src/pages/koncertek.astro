---
// src/pages/koncertek.astro
import MainLayout from '../layouts/MainLayout.astro';

// Az eredeti adataid [cite: 3, 4, 5, 6]
const concerts = [
  {
    date: '2026. Április 30.',
    isoDate: '2026-04-30',
    time: '18:00',
    band: 'Omega Forever Band',
    venue: 'Révkomárom, Komáromi Napok',
    link: '/videok/omega-forever'
  },
  {
    date: '2026. Június 27.',
    isoDate: '2026-06-27',
    time: '--:--',
    band: 'Omega Forever Band',
    venue: 'Debrőd',
    link: '/videok/omega-forever'
  },
  {
    date: '2026. Augusztus 15.',
    isoDate: '2026-08-15',
    time: '20:00',
    band: 'Omega Forever Band',
    venue: 'Vajka',
    link: '/videok/omega-forever'
  }
];

// Mai dátum megszerzése a szerveroldali szűréshez [cite: 19, 20]
const today = new Date();
today.setHours(0, 0, 0, 0);

// Csak a jövőbeli koncertek szűrése és rendezése
const upcomingConcerts = concerts
  .filter(c => new Date(c.isoDate) >= today)
  .sort((a, b) => a.isoDate.localeCompare(b.isoDate));
---

<MainLayout title="Koncertnaptár | Bukai Laci">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-20">
        <header class="mb-16 md:mb-24 text-center">
            <span class="text-cyan-400 font-mono text-sm tracking-[0.3em] uppercase italic">Élőben a színpadon</span>
            <h1 class="text-4xl sm:text-5xl md:text-7xl font-black mt-4 tracking-tighter text-white uppercase italic break-words">
                Koncertnaptár
            </h1>
            <div class="w-24 h-1 bg-cyan-500 mx-auto mt-8 rounded"></div>
        </header>

        <div class="space-y-6">
            {upcomingConcerts.length === 0 ? (
                <p class="text-center text-slate-500 text-lg">Jelenleg nincsenek meghirdetett koncertek. Nézz vissza később!</p>
            ) : (
                upcomingConcerts.map((c) => {
                    // PONTOS URL GENERÁLÁS: Ez fogja a hosszú linket létrehozni
                    const safeVenue = c.venue.toLowerCase()
                        .normalize("NFD").replace(/[\u0300-\u036f]/g, "") // Ékezetek eltávolítása
                        .replace(/[^a-z0-9]/g, '-') // Minden egyéb karakter kötőjelre
                        .replace(/-+/g, '-') // Dupla kötőjelek kiszűrése
                        .replace(/^-|-$/g, ''); // Szélekről kötőjelek levágása

                    const concertId = `${c.isoDate}-${safeVenue}`;
                    const shareUrl = `https://www.bukailaci.eu/koncert/${concertId}`;
                    const facebookShareLink = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;

                    return (
                        <div class="group relative overflow-hidden bg-slate-900/50 border border-white/5 hover:border-cyan-500/30 rounded-3xl p-6 md:p-8 transition-all duration-500 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 shadow-xl">

                            <div class="flex flex-col md:flex-row gap-6 md:gap-12 w-full">
                                {/* Dátum szekció [cite: 10, 11] */}
                                <div class="flex flex-col min-w-[180px]">
                                    <span class="text-cyan-400 font-black text-2xl md:text-3xl tracking-tighter italic">{c.date}</span>
                                    <span class="text-slate-500 font-mono text-sm mt-1">{c.time}</span>
                                </div>

                                {/* Információk [cite: 12, 13, 15] */}
                                <div class="flex flex-col justify-center">
                                    <h3 class="text-2xl font-bold text-white uppercase italic tracking-tighter group-hover:text-cyan-400 transition-colors duration-300">
                                        {c.band}
                                    </h3>
                                    <div class="flex items-center gap-2 mt-2 text-slate-400">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-cyan-500/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                        <span class="font-medium">{c.venue}</span>
                                    </div>
                                </div>
                            </div>

                            {/* Megosztás gomb */}
                            <div class="shrink-0 w-full md:w-auto">
                                <a
                                    href={facebookShareLink}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center justify-center gap-2 px-8 py-4 bg-[#1877F2]/10 hover:bg-[#1877F2] text-[#1877F2] hover:text-white border border-[#1877F2]/20 rounded-2xl transition-all duration-300 font-bold text-xs uppercase tracking-[0.2em] shadow-[0_0_20px_rgba(24,119,242,0.1)] hover:shadow-[0_0_30px_rgba(24,119,242,0.3)] w-full md:w-auto"
                                >
                                    <svg class="w-5 h-5 fill-currentColor" viewBox="0 0 24 24">
                                        <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
                                    </svg>
                                    <span>Megosztom</span>
                                </a>
                            </div>
                        </div>
                    );
                })
            )}
        </div>
    </div>
</MainLayout>