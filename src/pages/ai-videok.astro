---
// src/pages/ai-videok.astro
import MainLayout from "../layouts/MainLayout.astro";

/** * AI VIDEÓK BEOLVASÁSA:
 * Szigorúan az src/assets/ai-videok/ mappából olvassa be a fájlokat.
 */
const videoFiles = import.meta.glob("/src/assets/ai-videok/*.{mp4,webm}", {
  eager: true,
});
const videoPaths = Object.keys(videoFiles);

const title = "AI Videók | Bukai Laci";
---

<MainLayout title={title}>
  <section class="max-w-7xl mx-auto px-6 py-12">
    <!-- Bevezető (Csak a cím marad) -->
    <div class="mb-16 border-l-4 border-emerald-500 pl-6">
      <h1
        class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tighter uppercase italic"
      >
        AI <span class="text-emerald-500">Videók</span>
      </h1>
    </div>

    <!-- AI Videók Grid -->
    {
      videoPaths.length === 0 ? (
        <div class="bg-slate-900/30 border border-white/5 rounded-3xl p-20 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/10 mb-6 text-emerald-500">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-8 w-8"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"
              />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">
            Hamarosan érkeznek a videók
          </h3>
          <p class="text-slate-500 text-sm">
            Másold az mp4 videóidat az{" "}
            <code class="bg-slate-800 px-2 py-1 rounded text-emerald-400">
              src/assets/ai-videok/
            </code>{" "}
            mappába.
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {videoPaths.map((path) => {
            const fileName =
              path.split("/").pop()?.split(".")[0] || "AI Alkotás";
            const videoUrl = (videoFiles[path] as any).default;

            return (
              <div class="group space-y-6">
                <div class="relative aspect-video rounded-4xl overflow-hidden border border-white/10 bg-black shadow-2xl transition-all duration-500 group-hover:border-emerald-500/40">
                  {/* Az object-contain biztosítja, hogy a videó teljes kerete látsszon,
                  ne legyen vágás sem a tetején, sem az alján.
                */}
                  <video
                    src={videoUrl}
                    controls
                    loop
                    muted
                    playsinline
                    class="w-full h-full object-contain bg-black"
                  >
                    Sajnálom, a böngésződ nem támogatja a videólejátszást.
                  </video>

                  <div class="absolute top-4 right-4 pointer-events-none">
                    <span class="bg-black/60 backdrop-blur-md text-emerald-400 text-[9px] font-mono px-3 py-1 rounded-full border border-emerald-500/20 uppercase tracking-widest">
                      AI Content
                    </span>
                  </div>
                </div>

                <div class="px-2">
                  <h3 class="text-xl font-bold text-white group-hover:text-emerald-400 transition-colors uppercase tracking-tight italic">
                    {fileName.replace(/-/g, " ")}
                  </h3>
                </div>
              </div>
            );
          })}
        </div>
      )
    }
  </section>
</MainLayout>

<style>
  /* Letisztult lejátszó megjelenés */
  video {
    max-height: 100%;
    width: 100%;
  }
</style>
