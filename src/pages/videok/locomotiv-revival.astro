---
// src/pages/videok/locomotiv-revival.astro
import MainLayout from '../../layouts/MainLayout.astro';

const bandName = "Locomotiv Revival Band";
const videos = [
  { title: "Mindenki,Miénk itt a tér", id: "M5YxYppFgzg" },
  { title: "LGT 2013 mix", id: "91ZZ0K4ssio" },
];
---

<MainLayout title={`${bandName} | Videók`}>
    <div class="max-w-6xl mx-auto px-6 py-12">
        <header class="mb-16 text-right">
            <span class="text-emerald-400 font-mono text-sm tracking-[0.3em] uppercase">Live Performance</span>
            <h1 class="text-5xl md:text-7xl font-black mt-4 tracking-tighter italic text-white underline decoration-emerald-500/30 uppercase">
                {bandName}
            </h1>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            {videos.map((video) => (
                <div class="group relative bg-slate-900 rounded-[40px] overflow-hidden border border-white/5 hover:border-emerald-500/30 transition-all duration-500">
                    <div class="aspect-video w-full">
                        <iframe
                            class="w-full h-full"
                            src={`https://www.youtube.com/embed/${video.id}`}
                            title={video.title}
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen
                        ></iframe>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-white group-hover:text-emerald-400 transition-colors italic uppercase">
                            {video.title}
                        </h3>
                    </div>
                </div>
            ))}
        </div>
    </div>
</MainLayout>