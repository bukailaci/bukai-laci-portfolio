---
// src/pages/videok/omega-forever.astro
import MainLayout from '../../layouts/MainLayout.astro';

const bandName = "Omega Forever Band";
const videos = [
  { id: 'gdRqrh2s5Rc', title: 'Omega Forever Band - Kalinkovo 1' },
  { id: '-Ox17f9e6B4', title: 'Omega Forever Band - Kalinkovo 2' },
  { id: 'rtEgBhkcUyM', title: 'Omega Forever Band - Kalinkovo 3' },
  { id: 'vO5nDzsIwm0', title: 'Omega Forever Band - Kalinkovo 4' },
  { id: 'dG-BDGX6jxY', title: 'Omega Forever Band - Kalinkovo 5' },
];
---

<MainLayout title={`${bandName} | Videók`}>
    <div class="max-w-6xl mx-auto px-6 py-12">
        <header class="mb-16">
            <span class="text-cyan-400 font-mono text-sm tracking-[0.3em] uppercase">Drum Cam & Live</span>
            <h1 class="text-5xl md:text-7xl font-black mt-4 tracking-tighter italic text-white underline decoration-cyan-500/30 uppercase">
                {bandName}
            </h1>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            {videos.map((video) => (
                <div class="group relative bg-slate-900 rounded-[40px] overflow-hidden border border-white/5 hover:border-cyan-500/30 transition-all duration-500">
                    <div class="aspect-video w-full">
                        <iframe
                            class="w-full h-full"
                            src={`https://www.youtube.com/embed/${video.id}`}
                            title={video.title}
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen
                        ></iframe>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-white group-hover:text-cyan-400 transition-colors italic uppercase">
                            {video.title}
                        </h3>
                    </div>
                </div>
            ))}
        </div>
    </div>
</MainLayout>