---
// src/pages/videok.astro
import MainLayout from "../layouts/MainLayout.astro";

const bands = [
  {
    name: "Omega Forever Band",
    url: "/videok/omega-forever",
    desc: "Bukai Laci - Dobok",
    color: "from-cyan-500 to-blue-600",
    icon: "🥁",
  },
  {
    name: "Locomotiv Revival Band",
    url: "/videok/locomotiv-revival",
    desc: "Bukai Laci - Dobok",
    color: "from-emerald-500 to-teal-600",
    icon: "🤘",
  },
];
---

<MainLayout title="Videók | Bukai Laci">
  <div class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <header class="mb-20 text-center">
      <span
        class="text-cyan-400 font-mono text-sm tracking-[0.3em] uppercase italic"
        >Válaszd ki a zenekart</span
      >
      {/* JAVÍTÁS: pr-6 py-2 hozzáadva a dőlés miatt */}
      <h1
        class="text-6xl md:text-8xl font-black mt-4 tracking-tighter text-white uppercase italic pr-6 py-2"
      >
        VIDEÓK
      </h1>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
      {
        bands.map((band) => (
          <a
            href={band.url}
            class="group relative overflow-hidden rounded-[50px] bg-slate-900/50 border border-white/10 p-12 transition-all duration-500 hover:border-cyan-500/50 hover:-translate-y-4 hover:shadow-[0_20px_50px_rgba(6,182,212,0.15)] flex flex-col items-center text-center"
          >
            {/* ANIMÁLT HÁTTÉR AURA */}
            <div class="absolute inset-8 -z-10 overflow-visible pointer-events-none">
              <div class="animated-gradient absolute inset-0 opacity-0 group-hover:opacity-30 blur-[60px] transition-all duration-1000 scale-90 group-hover:scale-125" />
            </div>

            <div
              class={`absolute inset-0 bg-linear-to-br ${band.color} opacity-0 group-hover:opacity-5 transition-opacity duration-700`}
            />

            <div class="relative mb-10 text-7xl transform transition-transform duration-700 group-hover:scale-125 group-hover:rotate-12">
              {band.icon}
              <div
                class={`absolute inset-0 blur-2xl bg-linear-to-r ${band.color} opacity-0 group-hover:opacity-40 transition-opacity`}
              />
            </div>

            <div class="relative z-10 flex flex-col items-center">
              {/* JAVÍTÁS: pr-6 py-1 hozzáadva */}
              <h2 class="text-4xl md:text-5xl font-black text-white mb-4 italic uppercase tracking-tighter transition-all group-hover:text-cyan-400 pr-6 py-1">
                {band.name}
              </h2>

              <p class="text-slate-400 text-lg leading-relaxed max-w-xs font-light">
                {band.desc}
              </p>

              <div class="mt-12 flex items-center gap-3 text-white font-bold uppercase tracking-[0.2em] text-xs opacity-0 group-hover:opacity-100 transition-all translate-y-4 group-hover:translate-y-0">
                Megtekintés
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 text-cyan-400"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</MainLayout>

<style>
  .animated-gradient {
    background: linear-gradient(
      125deg,
      #06b6d4,
      #3b82f6,
      #10b981,
      #8b5cf6,
      #06b6d4
    );
    background-size: 250% 250%;
    animation: glow-flow 8s linear infinite;
  }
  @keyframes glow-flow {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
</style>
